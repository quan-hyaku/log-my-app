{
  "name": "@quan-hyaku/log-my-app",
  "version": "0.1.2",
  "description": "Browser logging library that intercepts console methods and persists logs to IndexedDB with localStorage fallback",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "logging",
    "console",
    "indexeddb",
    "browser",
    "debug"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/quan-hyaku/log-my-app"
  },
  "homepage": "https://github.com/quan-hyaku/log-my-app#readme",
  "bugs": {
    "url": "https://github.com/quan-hyaku/log-my-app/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "fake-indexeddb": "^6.2.5",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
